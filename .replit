modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/orahai-mobile: Expo"

[[workflows.workflow]]
name = "artifacts/orahai-mobile: Expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/orahai-mobile run dev"

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 19000
externalPort = 3001

[[ports]]
localPort = 19001
externalPort = 3002

[[ports]]
localPort = 22835
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
INITIAL_ADMIN_EMAIL = "orahai@proton.me"
