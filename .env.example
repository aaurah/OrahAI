# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-min-32-chars

GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://orahai:orahai_pass@localhost:5432/orahai

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Storage ──────────────────────────────────────────────────────────────────
# MinIO (local) or S3 (prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=orahai-workspaces
STORAGE_REGION=us-east-1

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# Model to use: gpt-4o | claude-3-5-sonnet-20241022
AI_MODEL=gpt-4o
AI_SERVICE_API_KEY=internal-service-key-change-me

# ─── Sandbox / Runner ─────────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
SANDBOX_IMAGE=orahai-sandbox:latest
SANDBOX_CPU_QUOTA=50000
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_NETWORK=orahai-sandbox-net
SANDBOX_TIMEOUT_SECONDS=30
WORKSPACE_BASE_DIR=/tmp/orahai-workspaces

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_id
STRIPE_TEAM_PRICE_ID=price_your_team_plan_id

# ─── Email (Resend / SendGrid) ────────────────────────────────────────────────
EMAIL_FROM=noreply@yourdomain.com
RESEND_API_KEY=re_your_resend_key

# ─── JWT (API internal auth) ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
