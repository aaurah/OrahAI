# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orahai

# ── API ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_secret
JWT_EXPIRES_IN=7d
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Services ──────────────────────────────────────────────────────────────────
SANDBOX_URL=http://localhost:5000
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_KEY=internal_change_me

# ── AI providers (add at least one) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=gpt-4o-mini

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_nextauth_secret

# ── OAuth (optional) ─────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
