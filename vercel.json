{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,

  "installCommand": "pnpm install",

  "buildCommand": "node artifacts/api-server/vercel-build.mjs && BASE_PATH=/ NODE_ENV=production pnpm --filter @workspace/orahai run build",

  "outputDirectory": "artifacts/orahai/dist/public",

  "framework": null,

  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "runtime": "nodejs22.x"
    }
  },

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js",
      "headers": { "Cache-Control": "no-store" }
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|json|map|webp|avif))",
      "dest": "/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
